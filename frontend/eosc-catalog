server {
    listen 80;
    server_name _;

    root /var/www/eosc-catalog;
    index index.html;

    location / {
        try_files $uri /index.html;
    }

    location /v1/ {
        proxy_pass http://127.0.0.1:8080/v1/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }
}
